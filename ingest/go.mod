// Force the post-split genproto modules. Without these pins, an older
// monolithic google.golang.org/genproto gets pulled in transitively
// (via grpc / grpc-gateway / aws-sdk telemetry), which ships the same
// googleapis/rpc/status and googleapis/api/httpbody import paths as
// the split modules and triggers `ambiguous import` errors.
require (
	google.golang.org/genproto/googleapis/api v0.0.0-20241104194629-dd2ea8efbc28 // indirect
	google.golang.org/genproto/googleapis/rpc v0.0.0-20241104194629-dd2ea8efbc28 // indirect
)
